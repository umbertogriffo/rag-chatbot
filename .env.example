# Project Configuration
PROJECT_NAME="Chatbot API"
VERSION="0.1.0"
API_V1_PREFIX="/api"
HOST="0.0.0.0"
PORT=8000

# Logging Configuration
LOG_LEVEL="INFO"

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# Model Configuration
DEFAULT_MODEL="llama-3.2"
DEFAULT_K=2
DEFAULT_MAX_NEW_TOKENS=512
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=50
DEFAULT_SYNTHESIS_STRATEGY="async-tree-summarization"
DEFAULT_CHAT_HISTORY_LENGTH=2
DEFAULT_NUM_RETRIEVALS=2

# WebSocket Configuration
WEBSOCKET_MAX_SIZE=10485760

# File Upload Configuration
ALLOWED_UPLOAD_EXTENSIONS=[".md"]
